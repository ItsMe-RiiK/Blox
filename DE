		MainFrame = Enum.KeyCode.LeftAlt,
	},
}

App.AddConnection = function(name, conn)
	if App.Connections[name] then
		App.Connections[name]:Disconnect()
	end
	App.Connections[name] = conn
end

local ESP_COLOR = Color3.fromRGB(200, 40, 40)
App.Features.ESP = {
	Enable = function()
		App.AddConnection("ESP_Loop", RunService.Heartbeat:Connect(function()
			for _, p in ipairs(Players:GetPlayers()) do
				if p ~= LocalPlayer then
					local char = p.Character
					if char then
						local head = char:FindFirstChild("Head")
						local hum = char:FindFirstChildOfClass("Humanoid")
						
						if head and hum and hum.Health > 0 then
							
							if not char:FindFirstChild("2PBT_ESP_HL") then
								local hl = Instance.new("Highlight")
								hl.Name = "2PBT_ESP_HL"
								hl.Adornee = char
								hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
								hl.OutlineTransparency = 0
								hl.OutlineColor = ESP_COLOR
								hl.FillTransparency = 1 
								hl.FillColor = ESP_COLOR
								hl.Parent = char
							end
							
							if not head:FindFirstChild("2PBT_ESP_BG") then
								local bg = Instance.new("BillboardGui")
								bg.Name = "2PBT_ESP_BG"
								bg.Adornee = head
								bg.Size = UDim2.new(0, 200, 0, 50) 
								bg.StudsOffset = Vector3.new(0, 4, 0) 
								bg.AlwaysOnTop = true
								bg.MaxDistance = math.huge
								bg.Parent = head
								
								local lab = Instance.new("TextLabel", bg)
								lab.Size = UDim2.new(1, 0, 1, 0)
								lab.BackgroundTransparency = 1
								lab.TextStrokeTransparency = 0
								lab.TextStrokeColor3 = Color3.new(0,0,0)
								lab.Font = Enum.Font.GothamBold
								lab.TextSize = 13
								lab.TextColor3 = ESP_COLOR
								lab.Text = p.Name
							end
						end
					end
				end
			end
		end))
	end,
	
	Disable = function()
		if App.Connections["ESP_Loop"] then App.Connections["ESP_Loop"]:Disconnect() end
		
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= LocalPlayer and p.Character then
				local hl = p.Character:FindFirstChild("2PBT_ESP_HL")
				if hl then hl:Destroy() end
				
				local head = p.Character:FindFirstChild("Head")
				if head then
					local bg = head:FindFirstChild("2PBT_ESP_BG")
					if bg then bg:Destroy() end
				end
			end
		end
	end
}


App.Features.Aimbot = {
	Enable = function()
		App.AddConnection("Aimbot_Render", RunService.RenderStepped:Connect(function()
			if not App.State.Aimbot then return end

			local cam = Workspace.CurrentCamera
			local closestPlayer = nil
			local shortestDist = math.huge
			local mousePos = UIS:GetMouseLocation()

			for _, p in ipairs(Players:GetPlayers()) do
				if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
					local hum = p.Character:FindFirstChildOfClass("Humanoid")
					if hum and hum.Health > 0 then
						local pos, onScreen = cam:WorldToViewportPoint(p.Character.Head.Position)
						if onScreen then
							local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
							if dist < shortestDist then
								closestPlayer = p
								shortestDist = dist
							end
						end
					end
				end
			end

			if closestPlayer and closestPlayer.Character and closestPlayer.Character:FindFirstChild("Head") then
				local headPos = closestPlayer.Character.Head.Position
				cam.CFrame = CFrame.new(cam.CFrame.Position, headPos)
			end
		end))
	end,

	Disable = function()
		if App.Connections["Aimbot_Render"] then App.Connections["Aimbot_Render"]:Disconnect() end
	end
}

local OriginalWalkSpeeds = {}
App.Features.WalkSpeed = {
	Enable = function()
		local char = LocalPlayer.Character
		if char then
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum then
				if not OriginalWalkSpeeds[char] then
					OriginalWalkSpeeds[char] = hum.WalkSpeed
				end
				hum.WalkSpeed = App.Config.WalkValue
			end
		end
	end,
	
	Disable = function()
		local char = LocalPlayer.Character
		if char then
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum and OriginalWalkSpeeds[char] then
				hum.WalkSpeed = OriginalWalkSpeeds[char]
			end
		end
	end,
	
	Update = function()
		local char = LocalPlayer.Character
		if char then
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum and hum.WalkSpeed ~= App.Config.WalkValue then
				if not OriginalWalkSpeeds[char] then
					OriginalWalkSpeeds[char] = hum.WalkSpeed
				end
				hum.WalkSpeed = App.Config.WalkValue
			end
		end
	end
}


