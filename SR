-- separate UI and Feature
App.UI.Init = function()
    pcall(function()
        if PlayerGui:FindFirstChild("SpoofPanelV3") then
            PlayerGui.SpoofPanelV3:Destroy()
        end
    end)

    local sg = Instance.new("ScreenGui", PlayerGui)
    sg.Name = "SpoofPanelV3"
    sg.ResetOnSpawn = false

    local MobileBtn = Instance.new("TextButton", sg)
    MobileBtn.Size = UDim2.new(0, 45, 0, 45)
    MobileBtn.Position = UDim2.new(1, -55, 0, 10)
    MobileBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    MobileBtn.Text = "⚙️"
    MobileBtn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", MobileBtn)

    local MainFrame = Instance.new("Frame", sg)
    MainFrame.Size = UDim2.new(0, 220, 0, 340)
    MainFrame.Position = UDim2.new(0.5, -110, 0.5, -170)
    MainFrame.BackgroundColor3 = Color3.fromRGB(28, 28, 30)
    MainFrame.Visible = false
    Instance.new("UICorner", MainFrame)

    local CloseBtn = Instance.new("TextButton", MainFrame)
    CloseBtn.Size = UDim2.new(0, 30, 0, 30)
    CloseBtn.Position = UDim2.new(1, -35, 0, 5)
    CloseBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    CloseBtn.Text = "X"
    CloseBtn.Font = Enum.Font.GothamBold
    CloseBtn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", CloseBtn)

    local dragging, dragInput, dragStart, startPos
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.AbsolutePosition
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local screen = workspace.CurrentCamera.ViewportSize
            
            local newX = math.clamp(startPos.X + delta.X, 0, screen.X - MainFrame.AbsoluteSize.X)
            local newY = math.clamp(startPos.Y + delta.Y, 0, screen.Y - MainFrame.AbsoluteSize.Y)
            
            MainFrame.Position = UDim2.new(0, newX, 0, newY)
        end
    end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)

    local function ToggleUI()
        MainFrame.Visible = not MainFrame.Visible
        MobileBtn.Visible = not MainFrame.Visible
    end
    MobileBtn.MouseButton1Click:Connect(ToggleUI)
    CloseBtn.MouseButton1Click:Connect(ToggleUI)
    UIS.InputBegan:Connect(function(i, g) if not g and i.KeyCode == App.Hotkeys.MainFrame then ToggleUI() end end)

    local Content = Instance.new("ScrollingFrame", MainFrame)
    Content.Size = UDim2.new(1, -10, 1, -45)
    Content.Position = UDim2.new(0, 5, 0, 40)
    Content.BackgroundTransparency = 1
    Content.ScrollBarThickness = 2
    local layout = Instance.new("UIListLayout", Content)
    layout.Padding = UDim.new(0, 5)

    local function CreateToggle(name, stateKey, feature)
        local btn = Instance.new("TextButton", Content)
        btn.Size = UDim2.new(1, 0, 0, 35)
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 42)
        btn.Text = name .. " [OFF]"
        btn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", btn)

        btn.MouseButton1Click:Connect(function()
            App.State[stateKey] = not App.State[stateKey]
            btn.Text = name .. (App.State[stateKey] and " [ON]" or " [OFF]")
            btn.BackgroundColor3 = App.State[stateKey] and Color3.fromRGB(80, 150, 220) or Color3.fromRGB(40, 40, 42)
            if feature then
                if App.State[stateKey] and feature.Enable then feature.Enable()
                elseif not App.State[stateKey] and feature.Disable then feature.Disable() end
            end
        end)
    end

    local function CreateInput(placeholder, configKey, updateFunc)
        local box = Instance.new("TextBox", Content)
        box.Size = UDim2.new(1, 0, 0, 35)
        box.BackgroundColor3 = Color3.fromRGB(35, 35, 37)
        box.PlaceholderText = placeholder
        box.Text = tostring(App.Config[configKey])
        box.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", box)
        box.FocusLost:Connect(function() 
            local val = tonumber(box.Text)
            if val then
                if updateFunc then updateFunc(val) else App.Config[configKey] = val end
            else
                box.Text = tostring(App.Config[configKey])
            end
        end)
    end

    CreateToggle("Spoof WalkSpeed", "SpoofWalkSpeed", App.Features.WalkSpeed)
    CreateInput("WalkSpeed Value", "SWS", App.Features.WalkSpeed.UpdateValue)
    CreateToggle("Spoof Fly", "SpoofFly", App.Features.Fly)
    CreateInput("Fly Speed Value", "FlySpeed")
    CreateToggle("NoClip", "NoClip", App.Features.NoClip)
    CreateToggle("Dex Explorer", "DexExplorer", { Enable = App.Features.DexExplorer })
    CreateToggle("Simple Spy", "SimpleSpy", { Enable = App.Features.SimpleSpy })
end

RunService.Heartbeat:Connect(function()
    App.Features.Fly.Update()
end)

App.UI.Init()
