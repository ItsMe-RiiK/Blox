local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local ScreenGui = Instance.new("ScreenGui")
local Frame = Instance.new("Frame")
local ToggleButton = Instance.new("TextButton")

ScreenGui.Parent = game.CoreGui
ScreenGui.Name = "SpoofGUI"

Frame.Parent = ScreenGui
Frame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
Frame.Position = UDim2.new(0.5, -75, 0.5, -25)
Frame.Size = UDim2.new(0, 150, 0, 50)
Frame.Active = true
Frame.Draggable = true

ToggleButton.Parent = Frame
ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
ToggleButton.Size = UDim2.new(1, 0, 1, 0)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.Text = "Spoof: OFF"
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.TextSize = 20

ToggleButton.MouseButton1Click:Connect(function()
    local karakter = LocalPlayer.Character
    local humanoid = karakter and karakter:FindFirstChild("Humanoid")

    if humanoid then
        SpoofAktif = not SpoofAktif
        
        if SpoofAktif then
            ToggleButton.Text = "Spoof: ON"
            ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
            humanoid.WalkSpeed = NilaiEksploit
        else
            ToggleButton.Text = "Spoof: OFF"
            ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            humanoid.WalkSpeed = NilaiAsli
        end
    end
end)

local NilaiAsli = 16 
local NilaiEksploit = 100
local SpoofAktif = false

local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, key)
    if SpoofAktif and not checkcaller() then
        if self:IsA("Humanoid") and self.Parent == LocalPlayer.Character and key == "WalkSpeed" then
            return NilaiAsli
        end
    end
    return oldIndex(self, key)
end)
