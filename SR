if not game:IsLoaded() then
	game.Loaded:Wait()
end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local App = {
	State = {
		SpoofWalkSpeed = false,
		SpoofFly = false,
	},

	Config = {
		WalkValueAsli = 16,
		WalkValueEksploit = 50,
		StateAsli = Enum.HumanoidStateType.Running,
	},

	Features = {},
	UI = {},
	Connections = {}
}

local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, key)
	if App.State.SpoofWalkSpeed and not checkcaller() then
		if self:IsA("Humanoid") and self.Parent == LocalPlayer.Character and key == "WalkSpeed" then
			return App.Config.WalkValueAsli
		end
	end
	return oldIndex(self, key)
end)

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
	local method = getnamecallmethod()
	
	if App.State.SpoofFly and not checkcaller() then
		if self:IsA("Humanoid") and self.Parent == LocalPlayer.Character and method == "GetState" then
			return App.Config.StateAsli
		end
	end
	return oldNamecall(self, ...)
end)

App.Features.WalkSpeed = {
	Enable = function()
		local char = LocalPlayer.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if hum then
			hum.WalkSpeed = App.Config.WalkValueEksploit
		end
	end,
	Disable = function()
		local char = LocalPlayer.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if hum then
			hum.WalkSpeed = App.Config.WalkValueAsli
		end
	end
}

App.Features.Fly = {
	Enable = function()
		local char = LocalPlayer.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if hum then
			hum.PlatformStand = true
		end
	end,
	Disable = function()
		local char = LocalPlayer.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if hum then
			hum.PlatformStand = false
		end
	end
}

App.UI.Init = function()
	pcall(function()
		local old = PlayerGui:FindFirstChild("SpoofUI")
		if old then old:Destroy() end
	end)

	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "SpoofUI"
	ScreenGui.ResetOnSpawn = false
	ScreenGui.Parent = PlayerGui

	local MainFrame = Instance.new("Frame", ScreenGui)
	MainFrame.Name = "MainFrame"
	MainFrame.Size = UDim2.new(0, 200, 0, 120)
	MainFrame.Position = UDim2.new(0.5, -100, 0.5, -60)
	MainFrame.BackgroundColor3 = Color3.fromRGB(28, 28, 30)
	MainFrame.Active = true
	MainFrame.Draggable = true
	Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

	local Title = Instance.new("TextLabel", MainFrame)
	Title.Size = UDim2.new(1, 0, 0, 30)
	Title.BackgroundTransparency = 1
	Title.Font = Enum.Font.GothamBold
	Title.TextSize = 14
	Title.TextColor3 = Color3.fromRGB(255, 255, 255)
	Title.Text = "Spoof Panel"

	local Content = Instance.new("Frame", MainFrame)
	Content.Size = UDim2.new(1, -10, 1, -40)
	Content.Position = UDim2.new(0, 5, 0, 35)
	Content.BackgroundTransparency = 1

	local listLayout = Instance.new("UIListLayout", Content)
	listLayout.SortOrder = Enum.SortOrder.LayoutOrder
	listLayout.Padding = UDim.new(0, 5)

	App.UI.CreateToggle = function(name, stateKey, featureModule)
		local btn = Instance.new("TextButton", Content)
		btn.Size = UDim2.new(1, 0, 0, 32)
		btn.BackgroundColor3 = Color3.fromRGB(36, 36, 36)
		btn.TextColor3 = Color3.fromRGB(235, 235, 235)
		btn.Font = Enum.Font.Gotham
		btn.TextSize = 14
		btn.Text = name .. " [OFF]"
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

		btn.MouseButton1Click:Connect(function()
			App.State[stateKey] = not App.State[stateKey]

			if featureModule then
				if App.State[stateKey] and featureModule.Enable then
					featureModule.Enable()
				end
				if not App.State[stateKey] and featureModule.Disable then
					featureModule.Disable()
				end
			end

			local isActive = App.State[stateKey]
			btn.Text = name .. " [" .. (isActive and "ON" or "OFF") .. "]"
			btn.BackgroundColor3 = isActive and Color3.fromRGB(80, 150, 220) or Color3.fromRGB(36, 36, 36)
		end)
	end

	App.UI.CreateToggle("Spoof WalkSpeed", "SpoofWalkSpeed", App.Features.WalkSpeed)
	App.UI.CreateToggle("Spoof Fly State", "SpoofFly", App.Features.Fly)
end

App.UI.Init()
