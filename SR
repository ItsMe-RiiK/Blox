if not game:IsLoaded() then
    game.Loaded:Wait()
end

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local App = {
    State = {
        SpoofWalkSpeed = false,
        SpoofFly = false,
        NoClip = false,
    },
    Config = {
        RWS = 16,
        SWS = 100,
        FlySpeed = 100,
        RTS = Enum.HumanoidStateType.Running,
    },
    Features = {},
    UI = {},
    Connections = {},
    Hotkeys = {
        MainFrame = Enum.KeyCode.LeftAlt
    }
}

local CachedHumanoid = nil
local function UpdateHumanoidCache()
    local char = LocalPlayer.Character
    CachedHumanoid = char and char:WaitForChild("Humanoid", 5)
end

LocalPlayer.CharacterAdded:Connect(UpdateHumanoidCache)
UpdateHumanoidCache()

local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, key)
    if App.State.SpoofWalkSpeed and not checkcaller() and self == CachedHumanoid and key == "WalkSpeed" then
        return App.Config.RWS
    end
    return oldIndex(self, key)
end)

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if App.State.SpoofFly and not checkcaller() and self == CachedHumanoid and method == "GetState" then
        return App.Config.RTS
    end
    return oldNamecall(self, ...)
end)

App.Features.WalkSpeed = {
    Enable = function()
        if not CachedHumanoid then return end
        CachedHumanoid.WalkSpeed = App.Config.SWS
        
        App.Connections.WSKeep = CachedHumanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            if App.State.SpoofWalkSpeed and CachedHumanoid.WalkSpeed ~= App.Config.SWS then
                CachedHumanoid.WalkSpeed = App.Config.SWS
            end
        end)
    end,
    Disable = function()
        if App.Connections.WSKeep then App.Connections.WSKeep:Disconnect() end
        if CachedHumanoid then CachedHumanoid.WalkSpeed = App.Config.RWS end
    end,
    UpdateValue = function(newVal)
        App.Config.SWS = newVal
        if App.State.SpoofWalkSpeed and CachedHumanoid then
            CachedHumanoid.WalkSpeed = newVal
        end
    end
}

App.Features.NoClip = {
    Enable = function()
        App.Connections.NoClip = RunService.Stepped:Connect(function()
            local char = LocalPlayer.Character
            if char then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end,
    Disable = function()
        if App.Connections.NoClip then App.Connections.NoClip:Disconnect() end
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    part.CanCollide = true
                end
            end
        end
    end
}

local flyVertical = 0
App.Features.Fly = {
    Enable = function()
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not root or not CachedHumanoid then return end
        CachedHumanoid.PlatformStand = true
        
        local bv = Instance.new("BodyVelocity", root)
        bv.Name = "SpoofFlyVelocity"
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Velocity = Vector3.new(0,0,0)

        local bg = Instance.new("BodyGyro", root)
        bg.Name = "SpoofFlyGyro"
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.P = 9e4
    end,
    Disable = function()
        if CachedHumanoid then CachedHumanoid.PlatformStand = false end
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            if root:FindFirstChild("SpoofFlyVelocity") then root.SpoofFlyVelocity:Destroy() end
            if root:FindFirstChild("SpoofFlyGyro") then root.SpoofFlyGyro:Destroy() end
        end
    end,
    Update = function()
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not root or not App.State.SpoofFly then return end
        
        local bv = root:FindFirstChild("SpoofFlyVelocity")
        local bg = root:FindFirstChild("SpoofFlyGyro")
        if not bv or not bg then return end

        local cam = workspace.CurrentCamera
        bg.CFrame = cam.CFrame

        local moveVector = Vector3.new(0,0,0)
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + Vector3.new(0,0,-1) end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector + Vector3.new(0,0,1) end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector + Vector3.new(-1,0,0) end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + Vector3.new(1,0,0) end

        if UIS:IsKeyDown(Enum.KeyCode.Space) then flyVertical = 1 
        elseif UIS:IsKeyDown(Enum.KeyCode.LeftControl) then flyVertical = -1 
        else flyVertical = 0 end

        local direction = (cam.CFrame.RightVector * moveVector.X) + (cam.CFrame.LookVector * -moveVector.Z)
        bv.Velocity = (direction + Vector3.new(0, flyVertical, 0)).Unit * App.Config.FlySpeed
        if moveVector.Magnitude == 0 and flyVertical == 0 then bv.Velocity = Vector3.new(0,0,0) end
    end
}

