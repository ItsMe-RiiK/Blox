if not game:IsLoaded() then
    game.Loaded:Wait()
end

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local App = {
    State = {
        SpoofWalkSpeed = false,
        SpoofFly = false,
    },
    Config = {
        WalkValueAsli = 16,
        WalkValueEksploit = 100,
        FlySpeed = 100,
        StateAsli = Enum.HumanoidStateType.Running,
    },
    Features = {},
    UI = {},
    Connections = {},
    Hotkeys = {
        MainFrame = Enum.KeyCode.LeftAlt
    }
}

local CachedHumanoid = nil
local function UpdateHumanoidCache()
    local char = LocalPlayer.Character
    CachedHumanoid = char and char:FindFirstChildOfClass("Humanoid")
end

LocalPlayer.CharacterAdded:Connect(UpdateHumanoidCache)
UpdateHumanoidCache()

local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, key)
    if App.State.SpoofWalkSpeed and not checkcaller() and self == CachedHumanoid and key == "WalkSpeed" then
        return App.Config.WalkValueAsli
    end
    return oldIndex(self, key)
end)

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if App.State.SpoofFly and not checkcaller() and self == CachedHumanoid and method == "GetState" then
        return App.Config.StateAsli
    end
    return oldNamecall(self, ...)
end)

App.Features.WalkSpeed = {
    Update = function()
        if App.State.SpoofWalkSpeed and CachedHumanoid then
            CachedHumanoid.WalkSpeed = App.Config.WalkValueEksploit
        end
    end
}

local flyVertical = 0
App.Features.Fly = {
    Enable = function()
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not root or not CachedHumanoid then return end

        CachedHumanoid.PlatformStand = true
        
        local bv = Instance.new("BodyVelocity", root)
        bv.Name = "SpoofFlyVelocity"
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Velocity = Vector3.new(0,0,0)

        local bg = Instance.new("BodyGyro", root)
        bg.Name = "SpoofFlyGyro"
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.P = 9e4
    end,
    
    Disable = function()
        if CachedHumanoid then CachedHumanoid.PlatformStand = false end
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            if root:FindFirstChild("SpoofFlyVelocity") then root.SpoofFlyVelocity:Destroy() end
            if root:FindFirstChild("SpoofFlyGyro") then root.SpoofFlyGyro:Destroy() end
        end
    end,

    Update = function()
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not root or not App.State.SpoofFly then return end
        
        local bv = root:FindFirstChild("SpoofFlyVelocity")
        local bg = root:FindFirstChild("SpoofFlyGyro")
        if not bv or not bg then return end

        local cam = workspace.CurrentCamera
        bg.CFrame = cam.CFrame

        local moveVector = Vector3.new(0,0,0)
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + Vector3.new(0,0,-1) end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector + Vector3.new(0,0,1) end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector + Vector3.new(-1,0,0) end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + Vector3.new(1,0,0) end

        if UIS:IsKeyDown(Enum.KeyCode.Space) then flyVertical = 1 
        elseif UIS:IsKeyDown(Enum.KeyCode.LeftControl) then flyVertical = -1 
        else flyVertical = 0 end

        local direction = (cam.CFrame.RightVector * moveVector.X) + (cam.CFrame.LookVector * -moveVector.Z)
        bv.Velocity = (direction + Vector3.new(0, flyVertical, 0)).Unit * App.Config.FlySpeed
        if moveVector.Magnitude == 0 and flyVertical == 0 then bv.Velocity = Vector3.new(0,0,0) end
    end
}

App.UI.Init = function()
    local sg = Instance.new("ScreenGui", PlayerGui)
    sg.Name = "SpoofPanelV2"
    sg.ResetOnSpawn = false

    local MobileBtn = Instance.new("TextButton", sg)
    MobileBtn.Size = UDim2.new(0, 45, 0, 45)
    MobileBtn.Position = UDim2.new(1, -55, 0, 10)
    MobileBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    MobileBtn.Text = "⚙️"
    MobileBtn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", MobileBtn)

    local MainFrame = Instance.new("Frame", sg)
    MainFrame.Size = UDim2.new(0, 220, 0, 300)
    MainFrame.Position = UDim2.new(0.5, -110, 0.5, -150)
    MainFrame.BackgroundColor3 = Color3.fromRGB(28, 28, 30)
    MainFrame.Visible = true
    Instance.new("UICorner", MainFrame)

    local dragging, dragInput, dragStart, startPos
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = MainFrame.Position
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    local function ToggleUI() MainFrame.Visible = not MainFrame.Visible end
    MobileBtn.MouseButton1Click:Connect(ToggleUI)
    UIS.InputBegan:Connect(function(i, g) if not g and i.KeyCode == App.Hotkeys.MainFrame then ToggleUI() end end)

    local Content = Instance.new("ScrollingFrame", MainFrame)
    Content.Size = UDim2.new(1, -10, 1, -40)
    Content.Position = UDim2.new(0, 5, 0, 35)
    Content.BackgroundTransparency = 1
    Content.ScrollBarThickness = 2
    local layout = Instance.new("UIListLayout", Content)
    layout.Padding = UDim.new(0, 5)

    local function CreateToggle(name, stateKey, feature)
        local btn = Instance.new("TextButton", Content)
        btn.Size = UDim2.new(1, 0, 0, 35)
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 42)
        btn.Text = name .. " [OFF]"
        btn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", btn)

        btn.MouseButton1Click:Connect(function()
            App.State[stateKey] = not App.State[stateKey]
            btn.Text = name .. (App.State[stateKey] and " [ON]" or " [OFF]")
            btn.BackgroundColor3 = App.State[stateKey] and Color3.fromRGB(80, 150, 220) or Color3.fromRGB(40, 40, 42)
            if feature then
                if App.State[stateKey] and feature.Enable then feature.Enable()
                elseif not App.State[stateKey] and feature.Disable then feature.Disable() end
            end
        end)
    end

    local function CreateInput(placeholder, configKey)
        local box = Instance.new("TextBox", Content)
        box.Size = UDim2.new(1, 0, 0, 35)
        box.BackgroundColor3 = Color3.fromRGB(35, 35, 37)
        box.PlaceholderText = placeholder
        box.Text = tostring(App.Config[configKey])
        box.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", box)
        box.FocusLost:Connect(function() App.Config[configKey] = tonumber(box.Text) or App.Config[configKey] end)
    end

    CreateToggle("Spoof WalkSpeed", "SpoofWalkSpeed")
    CreateInput("WalkSpeed Value", "WalkValueEksploit")
    CreateToggle("Spoof Fly", "SpoofFly", App.Features.Fly)
    CreateInput("Fly Speed Value", "FlySpeed")
end

RunService.Heartbeat:Connect(function()
    App.Features.WalkSpeed.Update()
    App.Features.Fly.Update()
end)

App.UI.Init()
